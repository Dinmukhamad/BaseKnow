APP_NAME=Contact Center Platform
ENVIRONMENT=dev
DEBUG=true

# ── База данных ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/baseknow
# "serverless" (default, NullPool) или "server" (connection pool)
DB_POOL_MODE=serverless

# ── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерируй: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── Trusted proxies (nginx / Cloudflare IP) ───────────────────────────────────
# Оставь пустым если нет reverse-proxy
TRUSTED_PROXIES=

# ── Seed (начальный администратор — только для dev) ───────────────────────────
# ОБЯЗАТЕЛЬНО: задай свой пароль, дефолта нет
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# ── Cloudflare R2 (необязательно, только для загрузки файлов) ─────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Rate limiter storage (необязательно, для multi-instance деплоя) ───────────
# LIMITER_STORAGE_URI=redis://default:password@host:6379/0
